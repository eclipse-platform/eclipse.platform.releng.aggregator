<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
	<modelVersion>4.0.0</modelVersion>
	<parent>
		<groupId>org.eclipse</groupId>
		<artifactId>products</artifactId>
		<version>4.38.0-SNAPSHOT</version>
	</parent>
	<artifactId>org.eclipse.sdk.ide</artifactId>
	<packaging>eclipse-repository</packaging>
	<name>[product] Eclipse SDK</name>
	<properties>
		<!-- product configuration -->
		<tycho.product.id>org.eclipse.sdk.ide</tycho.product.id>
		<tycho.product.rootFolder>eclipse</tycho.product.rootFolder>
		<tycho.product.rootFolder.macosx>Eclipse.app</tycho.product.rootFolder.macosx>
		<tycho.product.installSources>true</tycho.product.installSources>
		<!-- Signing -->
		<skip.dmg-package-aarch64>false</skip.dmg-package-aarch64>
		<skip.dmg-package-x86_64>false</skip.dmg-package-x86_64>
	</properties>
	<build>
		<plugins>
			<plugin>
				<groupId>org.eclipse.tycho</groupId>
				<artifactId>tycho-p2-director-plugin</artifactId>
				<executions>
					<execution>
						<id>materialize-products</id>
						<goals>
							<goal>materialize-products</goal>
						</goals>
						<phase>package</phase>
					</execution>
					<execution>
						<id>archive-products</id>
						<goals>
							<goal>archive-products</goal>
						</goals>
						<phase>pre-integration-test</phase>
					</execution>
				</executions>
			</plugin>
		</plugins>
	</build>
</project>
